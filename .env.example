# ─────────────────────────────────────────────────────────────────────────────
# DentCare Elite V35 — Variáveis de Ambiente
# Copie este ficheiro para .env e preencha os valores antes de iniciar.
# NUNCA cometa o ficheiro .env no controlo de versões.
# ─────────────────────────────────────────────────────────────────────────────

# ─── SERVIDOR ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── BASE DE DADOS (MySQL / TiDB) ────────────────────────────────────────────
# OBRIGATÓRIO — sem isto o servidor não arranca
DATABASE_URL=mysql://user:password@host:3306/dentcare

# ─── SESSÕES ─────────────────────────────────────────────────────────────────
# OBRIGATÓRIO — segredo para assinar cookies de sessão (mínimo 32 caracteres)
SESSION_SECRET=mude_este_valor_para_algo_seguro_e_longo_em_producao

# ─── OPENAI (IA e Análise de Imagem) ─────────────────────────────────────────
# OBRIGATÓRIO para funcionalidades de IA (Voice Briefing, Análise de Imagem, IA Preditiva)
OPENAI_API_KEY=sk-...

# ─── TWILIO / WHATSAPP ───────────────────────────────────────────────────────
# OBRIGATÓRIO para envio de mensagens WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── REDIS (Filas de Mensagens WhatsApp) ─────────────────────────────────────
# OPCIONAL — se não configurado, as mensagens WhatsApp são enviadas de forma síncrona
# Recomendado em produção para evitar timeouts
REDIS_URL=redis://localhost:6379

# ─── CORS ────────────────────────────────────────────────────────────────────
# OBRIGATÓRIO em produção — URL do frontend (sem barra final)
# Exemplo: https://app.dentcare.pt
ALLOWED_ORIGIN=https://app.dentcare.pt

# ─── REDES SOCIAIS (Social Hub) ──────────────────────────────────────────────
# OPCIONAL — necessário apenas se usar a funcionalidade de publicação em redes sociais

# Facebook / Instagram (Meta Graph API)
META_APP_ID=
META_APP_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# ─── ARMAZENAMENTO DE FICHEIROS (S3 / Compatível) ────────────────────────────
# OPCIONAL — necessário para persistir imagens de imagiologia na nuvem
S3_BUCKET=
S3_REGION=eu-west-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# ─── NOTIFICAÇÕES PUSH (App Mobile) ──────────────────────────────────────────
# OPCIONAL — necessário para notificações push na app mobile
FCM_SERVER_KEY=

# ─── CONFIGURAÇÕES DE SEGURANÇA ──────────────────────────────────────────────
# OPCIONAL — desativar apenas em desenvolvimento local
HELMET_CSP_ENABLED=true

# ─── GROQ (IA gratuita) ──────────────────────────────────────────────────────
# OPCIONAL — provider IA gratuito (14.400 req/dia)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────────────────────────────────────
# NOTAS IMPORTANTES:
# 1. DATABASE_URL, SESSION_SECRET e JWT_SECRET sao OBRIGATORIOS para arranque.
# 2. TWILIO_* é OBRIGATÓRIO para WhatsApp Marketing e lembretes automáticos.
# 3. ALLOWED_ORIGIN deve ser a URL exata do frontend em produção.
# 4. Em desenvolvimento, pode usar NODE_ENV=development para CORS permissivo.
# ─────────────────────────────────────────────────────────────────────────────
